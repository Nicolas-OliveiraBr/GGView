<a href="/games/<%= title %>" class="thumbCard-link">
  <div class="card card-custom bg-dark text-white">
    <div class="thumbTile">
      <img src="<%= item.coverUrl %>" alt="<%= item.name %>" class="thumbTileImg">
      <div class="card-info">
        <p>
          <%= item.name %>
        </p>
      </div>
    </div>

    <div class="card-img-overlay d-flex align-items-center"></div>
    <div class="card-content">
      <span class="rating">4.5</span>
      <div class="stars">
        <% for(let i=1; i <=5; i++) { %>
          <i class="
          bi 
          <%= i <= rating ? 'bi-star-fill star-filled' : 'bi-star-fill star-empty' %>
        "></i>
          <% } %>
      </div>
    </div>
  </div>
</a>